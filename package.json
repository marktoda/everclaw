    "lint:fix": "biome check --write src/",
    "test": "vitest --run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@slack/bolt": "^4.6.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "absurd-sdk": "github:marktoda/absurd#schedules&path:sdks/typescript",
    "discord.js": "^14.25.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.35.0",
    "marked": "^17.0.4",
    "openai": "^6.25.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.12.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
