# Required
ANTHROPIC_API_KEY=sk-ant-your-key

# Channel tokens — CHANNEL_<TYPE>=<token>
CHANNEL_TELEGRAM=your-telegram-bot-token
# CHANNEL_DISCORD=your-discord-bot-token
# CHANNEL_SLACK=xoxb-bot-token|xapp-app-token
# CHANNEL_WHATSAPP=1
# CHANNEL_GMAIL=1
# GMAIL_LABEL=everclaw          # Gmail label used for filtering incoming mail

# Optional: enables the web_search tool (free tier: 2000 queries/month)
# BRAVE_SEARCH_API_KEY=BSA...

# Optional: voice transcription (Telegram voice messages)
# OPENAI_API_KEY=sk-...

# Script env vars — SCRIPT_<NAME>=<value> (prefix stripped, scripts see <NAME>)
# SCRIPT_MY_API_KEY=secret123

# MCP server env vars — SERVER_<NAME>=<value> (prefix stripped)
# SERVER_GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxx

# Access control — comma-separated, fully prefixed IDs
# Leave unset for discovery mode (bot replies with your chat ID)
# ALLOWED_CHAT_IDS=telegram:123456789

# ──────────────────────────────────────────────────
# Non-secret config (environment variables, not .env)
# Set these in your shell, docker-compose.yml, or docker-compose.override.yml.
# Shown here for reference — defaults work out of the box.
# ──────────────────────────────────────────────────

# DATABASE_URL=postgresql://localhost/absurd
# QUEUE_NAME=assistant
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# MAX_HISTORY_MESSAGES=50
# WORKER_CONCURRENCY=2
# CLAIM_TIMEOUT=600
# SCRIPT_TIMEOUT=30
# LOG_LEVEL=info

# Mount extra directories for the agent (name:mode:path, comma-separated)
# EXTRA_DIRS=vaults:ro:/mnt/vaults,projects:rw:/mnt/projects
